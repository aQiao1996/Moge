# Docker Compose 基础配置
POSTGRES_USER=moge
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=moge
POSTGRES_PORT=5432
BACKEND_PORT=8888
FRONTEND_PORT=3000

# 后端配置
JWT_SECRET=change_me_at_least_32_characters_long
RUN_MIGRATIONS=true
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120
SWAGGER_ENABLED=false
TRUST_PROXY=true

# AI 配置
AI_PROVIDER=openai_compatible
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_MODEL=gpt-5.2
OPENAI_API_KEY=
OPENAI_MODEL=
MOONSHOT_API_KEY=
MOONSHOT_MODEL_NAME=
MOONSHOT_BASE_URL=
GEMINI_API_KEY=

# 前端/认证配置
NEXT_APP_API_URL=http://backend:8888
NEXTAUTH_SECRET=change_me_at_least_32_characters_long
NEXTAUTH_URL=http://localhost:3000
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
