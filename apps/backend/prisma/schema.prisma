// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

// * ==================== 配置 ====================
generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// * ==================== 用户表 ====================
model users {
  id                 Int                  @id @default(autoincrement())
  /// 用户登录账号，全局唯一
  username           String               @unique
  /// 用户邮箱，第三方登录时使用，全局唯一
  email              String?              @unique
  /// 邮箱验证通过的时间，未验证则为空
  emailVerifiedAt    DateTime?            @map("email_verified_at")
  /// bcrypt 哈希后的密码；OAuth 用户此处为空
  passwordHash       String?              @map("password_hash")
  /// 昵称
  name               String?
  /// 头像 URL
  avatarUrl          String?              @map("avatar_url")
  /// 记录创建时间
  createdAt          DateTime             @default(now()) @map("created_at")
  /// 记录更新时间
  updatedAt          DateTime             @updatedAt @map("updated_at")
  /// 该用户绑定的所有第三方账号
  accounts           accounts[]
  /// 所属的所有大纲
  outlines           outline[]
  /// 所属的所有项目
  projects           projects[]
  /// 参与协作的项目成员记录
  projectMemberships project_members[]
  /// 所属的所有角色设定
  characterSettings  character_settings[]
  /// 所属的所有系统设定
  systemSettings     system_settings[]
  /// 所属的所有世界设定
  worldSettings      world_settings[]
  /// 所属的所有辅助设定
  miscSettings       misc_settings[]
  /// 所属的所有个人/项目字典项
  dictItems          dict_items[]
  /// 所属的所有文稿
  manuscripts        manuscripts[]
  /// 创建的 AI 后台任务
  aiJobs             ai_jobs[]
}

// * ==================== 第三方账号关联表 ====================
model accounts {
  id                Int      @id @default(autoincrement())
  /// 关联的用户 id
  userId            Int      @map("user_id")
  /// 第三方提供商名称，例如 github / gitlab 
  provider          String
  /// 第三方返回的 uid（字符串）
  providerAccountId String   @map("provider_account_id")
  /// 原始 provider 数据，存 tokens、avatar_url 等 JSON
  providerData      Json?    @map("provider_data")
  /// 创建时间
  createdAt         DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt         DateTime @updatedAt @map("updated_at")
  /// 所属用户
  user              users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

// * ==================== 字典管理 ====================
/// 字典分类表
model dict_categories {
  id          Int          @id @default(autoincrement())
  /// 分类编码，如 'novel_types'
  code        String       @unique
  /// 分类名称，如 '小说类型'
  name        String
  /// 描述
  description String?
  /// 创建时间
  createdAt   DateTime     @default(now()) @map("created_at")
  /// 更新时间
  updatedAt   DateTime     @updatedAt @map("updated_at")
  /// 字典项
  items       dict_items[]
}

/// 字典项表
model dict_items {
  id           Int                  @id @default(autoincrement())
  /// 所属分类编码
  categoryCode String               @map("category_code")
  /// 显示标签，如 '科幻'
  label        String
  /// 存储值（既是编码也是存储值），如 'sci_fi'
  value        String
  /// 描述信息
  description  String?
  /// 排序
  sortOrder    Int                  @default(0) @map("sort_order")
  /// 是否启用
  isEnabled    Boolean              @default(true) @map("is_enabled")
  /// 词条作用域：系统、用户、项目
  scope        DictScope            @default(SYSTEM)
  /// 所属用户 ID，系统词条为空
  userId       Int?                 @map("user_id")
  /// 所属项目 ID，仅项目词条有值
  projectId    Int?                 @map("project_id")
  /// 共享状态
  shareStatus  DictShareStatus      @default(PRIVATE) @map("share_status")
  /// 词条版本号
  version      Int                  @default(1)
  /// 来源词条 ID，用于社区复制
  sourceItemId Int?                 @map("source_item_id")
  /// 创建时间
  createdAt    DateTime             @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime             @updatedAt @map("updated_at")
  /// 所属分类
  category     dict_categories      @relation(fields: [categoryCode], references: [code], onDelete: Cascade)
  /// 所属用户
  user         users?               @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属项目
  project      projects?            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// 版本历史
  versions     dict_item_versions[]

  @@index([categoryCode, scope, userId, projectId])
  @@index([shareStatus])
}

/// 字典词条作用域
enum DictScope {
  SYSTEM
  USER
  PROJECT
}

/// 字典词条共享状态
enum DictShareStatus {
  PRIVATE
  SHARED
  ARCHIVED
}

/// 字典词条版本历史表
model dict_item_versions {
  id          Int        @id @default(autoincrement())
  /// 所属字典项 ID
  dictItemId  Int        @map("dict_item_id")
  /// 快照版本号
  version     Int
  /// 快照显示标签
  label       String
  /// 快照存储值
  value       String
  /// 快照描述
  description String?
  /// 快照排序
  sortOrder   Int        @map("sort_order")
  /// 快照启用状态
  isEnabled   Boolean    @map("is_enabled")
  /// 版本创建时间
  createdAt   DateTime   @default(now()) @map("created_at")
  /// 所属字典项
  dictItem    dict_items @relation(fields: [dictItemId], references: [id], onDelete: Cascade)

  @@unique([dictItemId, version])
  @@index([dictItemId, version])
}

// * ==================== 小说大纲 ====================

/// 小说大纲表
model outline {
  id         Int               @id @default(autoincrement())
  /// 小说名称
  name       String
  /// 小说类型（存 value）
  type       String
  /// 故事时代背景
  era        String?
  /// 核心冲突描述
  conflict   String?           @db.Text
  /// 标签数组（Pg text[]）
  tags       String[]          @default([])
  /// 备注信息
  remark     String?           @db.Text
  /// 业务生命周期状态
  status     OutlineStatus     @default(DRAFT)
  /// 关联的设定集项目ID
  projectId  Int?              @map("project_id")
  /// 关联的角色设定ID列表
  characters String[]          @default([])
  /// 关联的系统设定ID列表
  systems    String[]          @default([])
  /// 关联的世界设定ID列表
  worlds     String[]          @default([])
  /// 关联的辅助设定ID列表
  misc       String[]          @default([])
  /// 所属用户 ID
  userId     Int               @map("user_id")
  /// 创建人关联
  user       users             @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 关联的设定集项目
  project    projects?         @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// 记录创建时间
  createdAt  DateTime          @default(now()) @map("created_at")
  /// 记录更新时间
  updatedAt  DateTime          @updatedAt @map("updated_at")
  /// 大纲内容（一对一）
  content    outline_content?
  /// 所属的卷
  volumes    outline_volume[]
  /// 无卷的直接章节（序章、后记等）
  chapters   outline_chapter[]

  @@index([userId, status])
  @@index([projectId])
  @@index([createdAt])
}

/// 大纲内容表
model outline_content {
  id        Int                       @id @default(autoincrement())
  /// 所属大纲ID
  outlineId Int                       @unique @map("outline_id")
  /// Markdown全文内容
  content   String                    @db.Text
  /// 内容版本号
  version   Int                       @default(1)
  /// 创建时间
  createdAt DateTime                  @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime                  @updatedAt @map("updated_at")
  /// 所属大纲
  outline   outline                   @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  /// 版本历史
  versions  outline_content_version[]
}

/// 卷表
model outline_volume {
  id          Int               @id @default(autoincrement())
  /// 所属大纲ID
  outlineId   Int               @map("outline_id")
  /// 卷名，如"第一卷 风起云涌"
  title       String
  /// 卷描述
  description String?           @db.Text
  /// 卷排序（使用十进制避免并发冲突）
  sortOrder   Decimal           @map("sort_order") @db.Decimal(10, 5)
  /// 创建时间
  createdAt   DateTime          @default(now()) @map("created_at")
  /// 更新时间
  updatedAt   DateTime          @updatedAt @map("updated_at")
  /// 所属大纲
  outline     outline           @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  /// 卷下的章节
  chapters    outline_chapter[]

  @@index([outlineId, sortOrder])
}

/// 章节表（元数据）
/// 注意：需在数据库迁移时添加 CHECK 约束：CHECK (outline_id IS NOT NULL OR volume_id IS NOT NULL)
model outline_chapter {
  id        Int                      @id @default(autoincrement())
  /// 所属大纲ID（用于无卷章节，如序章、后记）
  outlineId Int?                     @map("outline_id")
  /// 所属卷ID（用于正文章节）
  volumeId  Int?                     @map("volume_id")
  /// 章名，如"第一章 初入江湖"
  title     String
  /// 章节在卷内或大纲内的排序（使用十进制避免并发冲突）
  sortOrder Decimal                  @map("sort_order") @db.Decimal(10, 5)
  /// 创建时间
  createdAt DateTime                 @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime                 @updatedAt @map("updated_at")
  /// 所属大纲（无卷章节）
  outline   outline?                 @relation(fields: [outlineId], references: [id], onDelete: Cascade)
  /// 所属卷
  volume    outline_volume?          @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  /// 章节内容（一对一）
  content   outline_chapter_content?

  @@index([outlineId, sortOrder])
  @@index([volumeId, sortOrder])
  @@map("outline_chapter")
}

/// 章节内容表
model outline_chapter_content {
  id        Int                               @id @default(autoincrement())
  /// 所属章节ID
  chapterId Int                               @unique @map("chapter_id")
  /// 章节内容
  content   String                            @db.Text
  /// 内容版本号
  version   Int                               @default(1)
  /// 创建时间
  createdAt DateTime                          @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime                          @updatedAt @map("updated_at")
  /// 所属章节
  chapter   outline_chapter                   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  /// 版本历史
  versions  outline_chapter_content_version[]
}

/// 章节内容版本历史表
model outline_chapter_content_version {
  id            Int                     @id @default(autoincrement())
  /// 所属章节内容ID
  contentId     Int                     @map("content_id")
  /// 版本号
  version       Int
  /// 该版本的内容
  content       String                  @db.Text
  /// 版本创建时间
  createdAt     DateTime                @default(now()) @map("created_at")
  /// 所属章节内容
  contentRecord outline_chapter_content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, version])
  @@index([contentId, version])
}

/// 大纲内容版本历史表
model outline_content_version {
  id             Int             @id @default(autoincrement())
  /// 所属大纲内容ID
  contentId      Int             @map("content_id")
  /// 版本号
  version        Int
  /// 该版本的内容
  content        String          @db.Text
  /// 版本创建时间
  createdAt      DateTime        @default(now()) @map("created_at")
  /// 所属大纲内容
  outlineContent outline_content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, version])
  @@index([contentId, version])
}

/// 大纲业务状态枚举
enum OutlineStatus {
  DRAFT // 草稿 - 刚创建
  GENERATING // 生成中 - AI生成过程中
  GENERATED // 已生成 - AI生成完成但未保存
  PUBLISHED // 已发布 - 用户确认保存
  DISCARDED // 已放弃 - 软删除
}

// * ==================== 设定集系统 ====================

/// 小说项目表
model projects {
  id              Int                 @id @default(autoincrement())
  /// 项目名称
  name            String
  /// 项目类型（小说类型）
  type            String
  /// 项目描述
  description     String?             @db.Text
  /// 项目标签
  tags            String[]            @default([])
  /// 关联的角色设定ID列表
  characters      String[]            @default([])
  /// 关联的系统设定ID列表
  systems         String[]            @default([])
  /// 关联的世界设定ID列表
  worlds          String[]            @default([])
  /// 关联的辅助设定ID列表
  misc            String[]            @default([])
  /// 所属用户ID
  userId          Int                 @map("user_id")
  /// 创建时间
  createdAt       DateTime            @default(now()) @map("created_at")
  /// 更新时间
  updatedAt       DateTime            @updatedAt @map("updated_at")
  /// 所属用户
  user            users               @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 项目级字典项
  dictItems       dict_items[]
  /// 项目级 AI 配置
  aiConfig        project_ai_configs?
  /// 项目协作成员
  members         project_members[]
  /// 项目级 Prompt 预设
  aiPromptPresets ai_prompt_presets[]
  /// 项目关联大纲
  outlines         outline[]
  /// 项目 AI 后台任务
  aiJobs          ai_jobs[]
  /// 项目记忆
  memoryItems     project_memory_items[]
  /// 项目知识资料
  knowledgeDocuments knowledge_documents[]

  @@index([userId])
  @@index([createdAt])
}

/// 项目成员角色
enum ProjectMemberRole {
  OWNER
  EDITOR
  VIEWER
}

/// 项目协作成员表
model project_members {
  id        Int               @id @default(autoincrement())
  /// 所属项目 ID
  projectId Int               @map("project_id")
  /// 成员用户 ID
  userId    Int               @map("user_id")
  /// 成员角色
  role      ProjectMemberRole @default(VIEWER)
  /// 创建时间
  createdAt DateTime          @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime          @updatedAt @map("updated_at")
  /// 所属项目
  project   projects          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// 成员用户
  user      users             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId, role])
  @@index([projectId, role])
}

/// 项目级 AI 上下文长度策略
enum AiContextLengthStrategy {
  COMPACT
  BALANCED
  EXPANDED
}

/// AI 生成结果应用策略
enum AiResultApplyStrategy {
  CANDIDATE
  DIRECT_INSERT
}

/// 项目级 AI 配置表
model project_ai_configs {
  id                          Int                     @id @default(autoincrement())
  /// 所属项目 ID
  projectId                   Int                     @unique @map("project_id")
  /// AI 供应商
  provider                    String
  /// 模型名称
  model                       String
  /// 温度参数
  temperature                 Decimal                 @default(0.60) @db.Decimal(3, 2)
  /// 最大输出 token
  maxTokens                   Int                     @default(2000) @map("max_tokens")
  /// 默认续写预设 ID
  defaultContinuePresetId     Int?                    @map("default_continue_preset_id")
  /// 默认润色预设 ID
  defaultPolishPresetId       Int?                    @map("default_polish_preset_id")
  /// 默认扩写预设 ID
  defaultExpandPresetId       Int?                    @map("default_expand_preset_id")
  /// 默认大纲预设 ID
  defaultOutlinePresetId      Int?                    @map("default_outline_preset_id")
  /// 是否引用角色设定
  enableCharacterContext      Boolean                 @default(true) @map("enable_character_context")
  /// 是否引用系统设定
  enableSystemContext         Boolean                 @default(true) @map("enable_system_context")
  /// 是否引用世界设定
  enableWorldContext          Boolean                 @default(true) @map("enable_world_context")
  /// 是否引用辅助设定
  enableMiscContext           Boolean                 @default(true) @map("enable_misc_context")
  /// 是否引用章节摘要
  enableChapterSummaryContext Boolean                 @default(false) @map("enable_chapter_summary_context")
  /// 是否引用项目记忆
  enableProjectMemoryContext  Boolean                 @default(false) @map("enable_project_memory_context")
  /// 上下文长度策略
  contextLengthStrategy       AiContextLengthStrategy @default(BALANCED) @map("context_length_strategy")
  /// AI 结果应用策略
  resultApplyStrategy         AiResultApplyStrategy   @default(CANDIDATE) @map("result_apply_strategy")
  /// 超过该预估 token 数后走后台任务
  asyncTaskThreshold          Int                     @default(3000) @map("async_task_threshold")
  /// 创建时间
  createdAt                   DateTime                @default(now()) @map("created_at")
  /// 更新时间
  updatedAt                   DateTime                @updatedAt @map("updated_at")
  /// 所属项目
  project                     projects                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// 默认续写预设
  defaultContinuePreset       ai_prompt_presets?      @relation("ProjectAiConfigDefaultContinuePreset", fields: [defaultContinuePresetId], references: [id], onDelete: SetNull)
  /// 默认润色预设
  defaultPolishPreset         ai_prompt_presets?      @relation("ProjectAiConfigDefaultPolishPreset", fields: [defaultPolishPresetId], references: [id], onDelete: SetNull)
  /// 默认扩写预设
  defaultExpandPreset         ai_prompt_presets?      @relation("ProjectAiConfigDefaultExpandPreset", fields: [defaultExpandPresetId], references: [id], onDelete: SetNull)
  /// 默认大纲预设
  defaultOutlinePreset        ai_prompt_presets?      @relation("ProjectAiConfigDefaultOutlinePreset", fields: [defaultOutlinePresetId], references: [id], onDelete: SetNull)

  @@index([provider, model])
}

/// AI 生成任务类型
enum AiTaskType {
  OUTLINE_GENERATE
  MANUSCRIPT_CONTINUE
  MANUSCRIPT_POLISH
  MANUSCRIPT_EXPAND
  CHAPTER_SUMMARIZE
}

/// Prompt 预设作用域
enum AiPromptPresetScope {
  SYSTEM
  USER
  PROJECT
}

/// AI Prompt 预设主表
model ai_prompt_presets {
  id                     Int                         @id @default(autoincrement())
  /// 预设编码
  code                   String
  /// 预设名称
  name                   String
  /// 任务类型
  taskType               AiTaskType                  @map("task_type")
  /// 预设作用域
  scope                  AiPromptPresetScope         @default(SYSTEM)
  /// 所属项目 ID，项目级预设必填
  projectId              Int?                        @map("project_id")
  /// 描述
  description            String?                     @db.Text
  /// 是否系统预设
  isSystemPreset         Boolean                     @default(false) @map("is_system_preset")
  /// 是否启用
  isEnabled              Boolean                     @default(true) @map("is_enabled")
  /// 最新版本号
  latestVersion          Int                         @default(1) @map("latest_version")
  /// 创建人
  createdBy              Int?                        @map("created_by")
  /// 创建时间
  createdAt              DateTime                    @default(now()) @map("created_at")
  /// 更新时间
  updatedAt              DateTime                    @updatedAt @map("updated_at")
  /// 所属项目
  project                projects?                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// 使用该预设作为默认续写的项目配置
  defaultContinueConfigs project_ai_configs[]        @relation("ProjectAiConfigDefaultContinuePreset")
  /// 使用该预设作为默认润色的项目配置
  defaultPolishConfigs   project_ai_configs[]        @relation("ProjectAiConfigDefaultPolishPreset")
  /// 使用该预设作为默认扩写的项目配置
  defaultExpandConfigs   project_ai_configs[]        @relation("ProjectAiConfigDefaultExpandPreset")
  /// 使用该预设作为默认大纲的项目配置
  defaultOutlineConfigs  project_ai_configs[]        @relation("ProjectAiConfigDefaultOutlinePreset")
  /// 版本记录
  versions               ai_prompt_preset_versions[]

  @@unique([code, scope, projectId])
  @@index([taskType, scope, isEnabled])
  @@index([projectId, taskType, isEnabled])
}

/// AI Prompt 预设版本表
model ai_prompt_preset_versions {
  id                 Int               @id @default(autoincrement())
  /// 所属预设 ID
  presetId           Int               @map("preset_id")
  /// 版本号
  version            Int
  /// 系统提示词
  systemPrompt       String            @map("system_prompt") @db.Text
  /// 用户提示词模板
  userPromptTemplate String            @map("user_prompt_template") @db.Text
  /// 输出格式
  outputFormat       String?           @map("output_format")
  /// 参数 schema
  parameterSchema    Json?             @map("parameter_schema")
  /// 版本备注
  notes              String?           @db.Text
  /// 创建人
  createdBy          Int?              @map("created_by")
  /// 创建时间
  createdAt          DateTime          @default(now()) @map("created_at")
  /// 所属预设
  preset             ai_prompt_presets @relation(fields: [presetId], references: [id], onDelete: Cascade)

  @@unique([presetId, version])
  @@index([presetId, version])
}

/// AI 候选结果类型
enum AiCandidateType {
  TEXT
}

/// AI 候选结果应用状态
enum AiCandidateApplyStatus {
  PENDING
  APPLIED
  DISCARDED
}

/// AI 候选结果应用方式
enum AiCandidateApplyMode {
  INSERT_TAIL
  REPLACE_SELECTION
  OVERWRITE_DRAFT
  SAVE_AS_DRAFT
}

/// AI 后台任务状态
enum AiJobStatus {
  PENDING
  QUEUED
  RUNNING
  SUCCESS
  FAILED
  CANCELED
  PARTIAL_SUCCESS
}

/// 项目记忆状态
enum ProjectMemoryStatus {
  ACTIVE
  ARCHIVED
}

/// 项目资料状态
enum KnowledgeDocumentStatus {
  ACTIVE
  ARCHIVED
}

/// 项目记忆条目表
model project_memory_items {
  id         Int                 @id @default(autoincrement())
  /// 所属项目 ID
  projectId  Int                 @map("project_id")
  /// 记忆分类
  category   String
  /// 标题
  title      String
  /// 内容
  content    String              @db.Text
  /// 优先级，值越大越优先进入上下文
  priority   Int                 @default(0)
  /// 来源类型
  sourceType String              @default("MANUAL") @map("source_type")
  /// 来源 ID
  sourceId   Int?                @map("source_id")
  /// 状态
  status     ProjectMemoryStatus @default(ACTIVE)
  /// 创建人
  createdBy  Int?                @map("created_by")
  /// 创建时间
  createdAt  DateTime            @default(now()) @map("created_at")
  /// 更新时间
  updatedAt  DateTime            @updatedAt @map("updated_at")
  /// 所属项目
  project    projects            @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, status, priority])
  @@index([projectId, category])
}

/// 项目知识资料表
model knowledge_documents {
  id           Int                     @id @default(autoincrement())
  /// 所属项目 ID
  projectId    Int                     @map("project_id")
  /// 资料标题
  title        String
  /// 资料类型
  documentType String                  @map("document_type")
  /// 资料正文
  content      String                  @db.Text
  /// 来源标识
  source       String                  @default("MANUAL")
  /// 状态
  status       KnowledgeDocumentStatus @default(ACTIVE)
  /// 创建人
  createdBy    Int?                    @map("created_by")
  /// 创建时间
  createdAt    DateTime                @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime                @updatedAt @map("updated_at")
  /// 所属项目
  project      projects                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  /// 切片
  chunks       knowledge_chunks[]

  @@index([projectId, status, updatedAt])
  @@index([projectId, documentType])
}

/// 项目知识资料切片表
model knowledge_chunks {
  id         Int                 @id @default(autoincrement())
  /// 所属资料 ID
  documentId Int                 @map("document_id")
  /// 所属项目 ID
  projectId  Int                 @map("project_id")
  /// 切片序号
  chunkIndex Int                 @map("chunk_index")
  /// 切片内容
  content    String              @db.Text
  /// 关键词
  keywords   String[]            @default([])
  /// 切片摘要
  summary    String?             @db.Text
  /// 创建时间
  createdAt  DateTime            @default(now()) @map("created_at")
  /// 所属资料
  document   knowledge_documents @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([projectId])
}

/// AI 后台任务表
model ai_jobs {
  id                Int                     @id @default(autoincrement())
  /// 创建任务的用户 ID
  userId            Int                     @map("user_id")
  /// 所属项目 ID
  projectId         Int?                    @map("project_id")
  /// 所属大纲 ID
  outlineId         Int?                    @map("outline_id")
  /// 所属文稿 ID
  manuscriptId      Int?                    @map("manuscript_id")
  /// 所属章节 ID
  chapterId         Int?                    @map("chapter_id")
  /// 任务类型
  taskType          AiTaskType              @map("task_type")
  /// 任务状态
  status            AiJobStatus             @default(QUEUED)
  /// 优先级，值越大越优先
  priority          Int                     @default(0)
  /// AI 供应商
  provider          String?
  /// 模型名称
  model             String?
  /// Prompt 预设 ID
  presetId          Int?                    @map("preset_id")
  /// Prompt 预设版本
  presetVersion     Int?                    @map("preset_version")
  /// 输入参数快照
  inputPayload      Json?                   @map("input_payload")
  /// 上下文元信息
  contextMeta       Json?                   @map("context_meta")
  /// 结果摘要
  resultSummary     Json?                   @map("result_summary")
  /// 错误信息
  errorMessage      String?                 @map("error_message") @db.Text
  /// 已重试次数
  retryCount        Int                     @default(0) @map("retry_count")
  /// 最大重试次数
  maxRetries        Int                     @default(0) @map("max_retries")
  /// 下次重试时间
  nextRetryAt       DateTime?               @map("next_retry_at")
  /// 锁定时间
  lockedAt          DateTime?               @map("locked_at")
  /// 锁定 worker 标识
  lockedBy          String?                 @map("locked_by")
  /// worker 心跳时间
  heartbeatAt       DateTime?               @map("heartbeat_at")
  /// 开始时间
  startedAt         DateTime?               @map("started_at")
  /// 结束时间
  finishedAt        DateTime?               @map("finished_at")
  /// 创建时间
  createdAt         DateTime                @default(now()) @map("created_at")
  /// 更新时间
  updatedAt         DateTime                @updatedAt @map("updated_at")
  /// 所属用户
  user              users                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属项目
  project           projects?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  /// 事件记录
  events            ai_job_events[]
  /// 生成记录
  generationRecords ai_generation_records[]

  @@index([userId, status, createdAt])
  @@index([projectId, status, createdAt])
  @@index([status, priority, nextRetryAt, createdAt])
  @@index([lockedAt])
}

/// AI 后台任务事件表
model ai_job_events {
  id        Int      @id @default(autoincrement())
  /// 所属任务 ID
  jobId     Int      @map("job_id")
  /// 事件类型
  eventType String   @map("event_type")
  /// 事件消息
  message   String?  @db.Text
  /// 事件负载
  payload   Json?
  /// 创建时间
  createdAt DateTime @default(now()) @map("created_at")
  /// 所属任务
  job       ai_jobs  @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

/// AI 生成记录表
model ai_generation_records {
  id              Int                        @id @default(autoincrement())
  /// 后台任务 ID，Phase A 同步调用为空
  jobId           Int?                       @map("job_id")
  /// 所属项目 ID
  projectId       Int?                       @map("project_id")
  /// 所属大纲 ID
  outlineId       Int?                       @map("outline_id")
  /// 任务类型
  taskType        AiTaskType                 @map("task_type")
  /// AI 供应商
  provider        String
  /// 模型名称
  model           String
  /// Prompt 预设 ID
  presetId        Int?                       @map("preset_id")
  /// Prompt 预设版本
  presetVersion   Int?                       @map("preset_version")
  /// 请求参数快照
  requestPayload  Json?                      @map("request_payload")
  /// 上下文快照
  contextSnapshot Json?                      @map("context_snapshot")
  /// 模型输出文本
  outputText      String?                    @map("output_text") @db.Text
  /// token 使用情况
  tokenUsage      Json?                      @map("token_usage")
  /// 请求耗时
  latencyMs       Int?                       @map("latency_ms")
  /// 调用状态
  status          String
  /// 错误信息
  errorMessage    String?                    @map("error_message") @db.Text
  /// 创建时间
  createdAt       DateTime                   @default(now()) @map("created_at")
  /// 候选结果
  candidates      ai_generation_candidates[]
  /// 所属后台任务
  job             ai_jobs?                   @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([projectId, taskType, createdAt])
  @@index([outlineId, taskType, createdAt])
  @@index([provider, model])
  @@index([jobId])
}

/// AI 生成候选结果表
model ai_generation_candidates {
  id                    Int                    @id @default(autoincrement())
  /// 所属生成记录 ID
  generationRecordId    Int                    @map("generation_record_id")
  /// 所属项目 ID
  projectId             Int?                   @map("project_id")
  /// 所属大纲 ID
  outlineId             Int?                   @map("outline_id")
  /// 所属文稿 ID
  manuscriptId          Int?                   @map("manuscript_id")
  /// 所属章节 ID
  chapterId             Int?                   @map("chapter_id")
  /// 候选类型
  candidateType         AiCandidateType        @default(TEXT) @map("candidate_type")
  /// 目标对象类型
  targetType            String                 @map("target_type")
  /// 目标对象 ID
  targetId              Int?                   @map("target_id")
  /// 目标内容版本
  targetContentVersion  Int?                   @map("target_content_version")
  /// 目标内容哈希
  expectedContentHash   String?                @map("expected_content_hash")
  /// 候选内容
  content               String                 @db.Text
  /// diff 元信息
  diffMeta              Json?                  @map("diff_meta")
  /// 应用状态
  applyStatus           AiCandidateApplyStatus @default(PENDING) @map("apply_status")
  /// 采纳人
  appliedBy             Int?                   @map("applied_by")
  /// 采纳时间
  appliedAt             DateTime?              @map("applied_at")
  /// 采纳方式
  applyMode             AiCandidateApplyMode?  @map("apply_mode")
  /// 采纳后的内容版本
  appliedContentVersion Int?                   @map("applied_content_version")
  /// 创建时间
  createdAt             DateTime               @default(now()) @map("created_at")
  /// 所属生成记录
  generationRecord      ai_generation_records  @relation(fields: [generationRecordId], references: [id], onDelete: Cascade)

  @@index([projectId, applyStatus, createdAt])
  @@index([manuscriptId, chapterId, applyStatus])
  @@index([generationRecordId])
}

/// 角色设定表
model character_settings {
  id            Int      @id @default(autoincrement())
  /// 角色名称
  name          String
  /// 角色类型（0-主角, 1-重要配角, 2-普通配角, 3-反派, 4-路人）
  type          Int?
  /// 性别（1-男, 2-女, 3-其他）
  gender        Int?
  /// 年龄
  age           String?
  /// 身高
  height        String?
  /// 外貌描述
  appearance    String?  @db.Text
  /// 性格特点
  personality   String?  @db.Text
  /// 出身背景
  background    String?  @db.Text
  /// 职业身份
  occupation    String?
  /// 实力等级
  powerLevel    String?
  /// 特殊能力
  abilities     String?  @db.Text
  /// 角色关系（JSON数组）
  /// 格式: [{relatedCharacter, customRelatedCharacter, relationshipType, customRelationshipType, relationshipDesc}]
  relationships Json?
  /// 标签
  tags          String[] @default([])
  /// 备注
  remarks       String?  @db.Text
  /// 所属用户ID
  userId        Int      @map("user_id")
  /// 创建时间
  createdAt     DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt     DateTime @updatedAt @map("updated_at")
  /// 所属用户
  user          users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
}

/// 系统设定表
model system_settings {
  id          Int      @id @default(autoincrement())
  /// 系统名称
  name        String
  /// 系统类型
  type        String?
  /// 系统描述
  description String?  @db.Text
  /// 功能模块（JSON数组）
  /// 格式: [{name, description, mechanism, trigger, limitation}]
  modules     Json?
  /// 等级体系（JSON数组）
  levels      Json?
  /// 道具装备（JSON数组）
  /// 格式: [{name, category, description, attributes, obtainMethod}]
  items       Json?
  /// 数值参数（JSON数组）
  parameters  Json?
  /// 运作规则
  rules       String?  @db.Text
  /// 触发条件
  triggers    String?  @db.Text
  /// 限制约束
  constraints String?  @db.Text
  /// 标签
  tags        String[] @default([])
  /// 备注
  remarks     String?  @db.Text
  /// 所属用户ID
  userId      Int      @map("user_id")
  /// 创建时间
  createdAt   DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt   DateTime @updatedAt @map("updated_at")
  /// 所属用户
  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
}

/// 世界设定表
model world_settings {
  id          Int      @id @default(autoincrement())
  /// 世界名称
  name        String
  /// 世界类型
  type        String?
  /// 时代背景
  era         String?
  /// 世界描述
  description String?  @db.Text
  /// 地理环境（JSON数组）
  geography   Json?
  /// 政治势力（JSON数组）
  politics    Json?
  /// 文化体系（JSON数组）
  culture     Json?
  /// 修炼/力量体系（JSON数组）
  powerSystem Json?    @map("power_system")
  /// 历史脉络（JSON对象）
  history     Json?
  /// 标签
  tags        String[] @default([])
  /// 备注
  remarks     String?  @db.Text
  /// 所属用户ID
  userId      Int      @map("user_id")
  /// 创建时间
  createdAt   DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt   DateTime @updatedAt @map("updated_at")
  /// 所属用户
  user        users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
}

/// 辅助设定表
model misc_settings {
  id           Int      @id @default(autoincrement())
  /// 设定名称
  name         String
  /// 设定类型
  type         String?
  /// 设定描述
  description  String?  @db.Text
  /// 灵感记录（JSON数组）
  inspirations Json?
  /// 参考资料（JSON数组）
  references   Json?
  /// 创作笔记（JSON数组）
  notes        Json?
  /// 专业术语（JSON数组）
  terminology  Json?
  /// 模板库（JSON数组）
  templates    Json?
  /// 项目标签（JSON数组）
  projectTags  Json?    @map("project_tags")
  /// 标签
  tags         String[] @default([])
  /// 备注
  remarks      String?  @db.Text
  /// 所属用户ID
  userId       Int      @map("user_id")
  /// 创建时间
  createdAt    DateTime @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime @updatedAt @map("updated_at")
  /// 所属用户
  user         users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([name])
}

// * ==================== 文稿系统 ====================

/// 文稿表
model manuscripts {
  id                  Int                  @id @default(autoincrement())
  /// 文稿名称
  name                String
  /// 文稿描述
  description         String?              @db.Text
  /// 小说类型
  type                String?
  /// 标签数组
  tags                String[]             @default([])
  /// 业务状态
  status              ManuscriptStatus     @default(DRAFT)
  /// 关联的大纲ID（仅用于记录来源，不是外键，大纲删除不影响文稿）
  outlineId           Int?                 @map("outline_id")
  /// 关联的设定集项目ID（优先使用，如果存在则忽略下面四个数组）
  projectId           Int?                 @map("project_id")
  /// 关联的角色设定ID列表（仅当projectId为空时使用）
  characters          String[]             @default([])
  /// 关联的系统设定ID列表（仅当projectId为空时使用）
  systems             String[]             @default([])
  /// 关联的世界设定ID列表（仅当projectId为空时使用）
  worlds              String[]             @default([])
  /// 关联的辅助设定ID列表（仅当projectId为空时使用）
  misc                String[]             @default([])
  /// 总字数（冗余字段，保存内容时自动计算更新）
  totalWords          Int                  @default(0) @map("total_words")
  /// 已发布字数（所有已发布章节的字数之和）
  publishedWords      Int                  @default(0) @map("published_words")
  /// 目标字数（用户设定的创作目标）
  targetWords         Int?                 @map("target_words")
  /// 封面图URL
  coverUrl            String?              @map("cover_url")
  /// 最后编辑的章节ID（用于快速定位到上次编辑位置）
  lastEditedChapterId Int?                 @map("last_edited_chapter_id")
  /// 最后编辑时间
  lastEditedAt        DateTime?            @map("last_edited_at")
  /// 软删除时间（为空表示未删除）
  deletedAt           DateTime?            @map("deleted_at")
  /// 所属用户ID
  userId              Int                  @map("user_id")
  /// 创建时间
  createdAt           DateTime             @default(now()) @map("created_at")
  /// 更新时间
  updatedAt           DateTime             @updatedAt @map("updated_at")
  /// 所属用户
  user                users                @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// 所属的卷
  volumes             manuscript_volume[]
  /// 无卷的直接章节（序章、后记等）
  chapters            manuscript_chapter[]

  @@index([userId, status])
  @@index([userId, deletedAt]) // 用于查询未删除的文稿
  @@index([createdAt])
  @@index([updatedAt])
  @@index([totalWords])
  @@index([lastEditedAt])
}

/// 文稿卷表
model manuscript_volume {
  id           Int                  @id @default(autoincrement())
  /// 所属文稿ID
  manuscriptId Int                  @map("manuscript_id")
  /// 卷名，如"第一卷 风起云涌"
  title        String
  /// 卷描述
  description  String?              @db.Text
  /// 卷排序（使用十进制避免并发冲突）
  sortOrder    Decimal              @map("sort_order") @db.Decimal(10, 5)
  /// 卷字数（冗余字段）
  wordCount    Int                  @default(0) @map("word_count")
  /// 创建时间
  createdAt    DateTime             @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime             @updatedAt @map("updated_at")
  /// 所属文稿
  manuscript   manuscripts          @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  /// 卷下的章节
  chapters     manuscript_chapter[]

  @@index([manuscriptId, sortOrder])
}

/// 文稿章节表（元数据）
/// 注意：需在数据库迁移时添加 CHECK 约束：CHECK (manuscript_id IS NOT NULL OR volume_id IS NOT NULL)
model manuscript_chapter {
  id           Int                         @id @default(autoincrement())
  /// 所属文稿ID（用于无卷章节，如序章、后记）
  manuscriptId Int?                        @map("manuscript_id")
  /// 所属卷ID（用于正文章节）
  volumeId     Int?                        @map("volume_id")
  /// 章名，如"第一章 初入江湖"
  title        String
  /// 章节在卷内或文稿内的排序（使用十进制避免并发冲突）
  sortOrder    Decimal                     @map("sort_order") @db.Decimal(10, 5)
  /// 章节字数（冗余字段）
  wordCount    Int                         @default(0) @map("word_count")
  /// 章节状态（草稿/定时发布/已发布）
  status       ChapterStatus               @default(DRAFT)
  /// 发布时间（首次发布时间）
  publishedAt  DateTime?                   @map("published_at")
  /// 定时发布时间
  scheduledAt  DateTime?                   @map("scheduled_at")
  /// 创建时间
  createdAt    DateTime                    @default(now()) @map("created_at")
  /// 更新时间
  updatedAt    DateTime                    @updatedAt @map("updated_at")
  /// 所属文稿（无卷章节）
  manuscript   manuscripts?                @relation(fields: [manuscriptId], references: [id], onDelete: Cascade)
  /// 所属卷
  volume       manuscript_volume?          @relation(fields: [volumeId], references: [id], onDelete: Cascade)
  /// 章节内容（一对一）
  content      manuscript_chapter_content?
  /// 章节摘要（一对一）
  summary      chapter_summaries?

  @@index([manuscriptId, sortOrder])
  @@index([volumeId, sortOrder])
  @@index([status])
  @@index([publishedAt])
  @@index([scheduledAt])
}

/// 章节摘要表
model chapter_summaries {
  id            Int                @id @default(autoincrement())
  /// 所属章节 ID
  chapterId     Int                @unique @map("chapter_id")
  /// 所属项目 ID
  projectId     Int?               @map("project_id")
  /// 摘要内容
  summary       String             @db.Text
  /// 摘要类型
  summaryType   String             @default("MANUAL") @map("summary_type")
  /// 摘要来源正文版本
  sourceVersion Int?               @map("source_version")
  /// 生成人或维护人
  generatedBy   Int?               @map("generated_by")
  /// 创建时间
  createdAt     DateTime           @default(now()) @map("created_at")
  /// 更新时间
  updatedAt     DateTime           @updatedAt @map("updated_at")
  /// 所属章节
  chapter       manuscript_chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@index([projectId, updatedAt])
}

/// 文稿章节内容表
model manuscript_chapter_content {
  id        Int                                  @id @default(autoincrement())
  /// 所属章节ID
  chapterId Int                                  @unique @map("chapter_id")
  /// 章节内容（Markdown）
  content   String                               @db.Text
  /// 内容版本号
  version   Int                                  @default(1)
  /// 创建时间
  createdAt DateTime                             @default(now()) @map("created_at")
  /// 更新时间
  updatedAt DateTime                             @updatedAt @map("updated_at")
  /// 所属章节
  chapter   manuscript_chapter                   @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  /// 版本历史
  versions  manuscript_chapter_content_version[]
}

/// 文稿章节内容版本历史表
model manuscript_chapter_content_version {
  id            Int                        @id @default(autoincrement())
  /// 所属章节内容ID
  contentId     Int                        @map("content_id")
  /// 版本号
  version       Int
  /// 该版本的内容
  content       String                     @db.Text
  /// 版本创建时间
  createdAt     DateTime                   @default(now()) @map("created_at")
  /// 所属章节内容
  contentRecord manuscript_chapter_content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@unique([contentId, version])
  @@index([contentId, version])
}

/// 文稿业务状态枚举
enum ManuscriptStatus {
  DRAFT // 草稿 - 构思中
  IN_PROGRESS // 进行中 - 正在创作
  COMPLETED // 已完结 - 创作完成
  PUBLISHED // 已发布 - 发布到平台
  ABANDONED // 已放弃 - 软删除
}

/// 章节状态枚举
enum ChapterStatus {
  DRAFT // 草稿 - 未发布
  SCHEDULED // 定时发布 - 等待到点发布
  PUBLISHED // 已发布
}
